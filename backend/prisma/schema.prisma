generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model accounts {
  account_id Int      @id @default(autoincrement())
  full_name  String   @db.VarChar(150)
  email      String   @unique(map: "accounts_unique") @db.VarChar(150)
  password   String   @db.VarChar(255)
  role       String   @default("learner") @db.VarChar(50)
  status     String   @default("active") @db.VarChar(50)
  created_at DateTime @default(now()) @db.DateTime(0)

  favorite_vocabularies favorite_vocabularies[]
  study_sessions study_sessions[]
  vocabulary_progress vocabulary_progress[]
  study_goals study_goals[]

}

model lessons {
  lesson_id   Int     @id @default(autoincrement())
  lesson_name String  @db.VarChar(255)
  jlpt_level  String  @db.VarChar(10)
  total_words Int     @default(0)

  vocabularies vocabularies[]
}

model vocabularies {
  vocabulary_id      Int     @id @default(autoincrement())
  lesson_id          Int
  word               String  @db.VarChar(100)
  reading            String? @db.VarChar(100)
  kanji_meaning      String? @db.VarChar(100)
  vietnamese_meaning String  @db.VarChar(255)
  example_sentence   String? @db.VarChar(255)
  audio_url          String? @db.VarChar(255)
  jlpt_level         String  @db.VarChar(10)

  lesson lessons @relation(fields: [lesson_id], references: [lesson_id])

  questions questions[]

  favorite_vocabularies favorite_vocabularies[]
  vocabulary_progress vocabulary_progress[]
}

model questions {
  question_id    Int     @id @default(autoincrement())
  vocabulary_id  Int
  content        String  @db.VarChar(255)
  question_type  String  @db.VarChar(50)
  correct_answer String  @db.VarChar(255)

  vocabulary vocabularies @relation(fields: [vocabulary_id], references: [vocabulary_id])
  question_results question_results[]
}

model favorite_vocabularies {
  favorite_vocabulary_id Int      @id @default(autoincrement())
  account_id             Int
  vocabulary_id          Int
  added_date             DateTime @default(now())

  account    accounts     @relation(fields: [account_id], references: [account_id])
  vocabulary vocabularies @relation(fields: [vocabulary_id], references: [vocabulary_id])

  @@unique([account_id, vocabulary_id])
}

model study_sessions {
  session_id      Int      @id @default(autoincrement())
  account_id      Int
  start_time      DateTime @default(now())
  end_time        DateTime?
  total_questions Int      @default(0)
  correct_answers Int      @default(0)
  session_type    String   @db.VarChar(50)

  account          accounts           @relation(fields: [account_id], references: [account_id])
  question_results question_results[]
}

model question_results {
  result_id   Int      @id @default(autoincrement())
  session_id  Int
  question_id Int
  user_answer String?  @db.VarChar(255)
  is_correct  Boolean
  answered_at DateTime @default(now())

  session  study_sessions @relation(fields: [session_id], references: [session_id])
  question questions       @relation(fields: [question_id], references: [question_id])
}

model vocabulary_progress {
  progress_id      Int       @id @default(autoincrement())
  account_id       Int
  vocabulary_id    Int

  repetition_count Int       @default(0)
  ease_factor      Float     @default(2.5)
  interval_days    Int       @default(1)

  last_reviewed_at DateTime?
  next_review_at   DateTime?

  account    accounts     @relation(fields: [account_id], references: [account_id])
  vocabulary vocabularies @relation(fields: [vocabulary_id], references: [vocabulary_id])

  @@unique([account_id, vocabulary_id])
}

model study_goals {
  goal_id     Int      @id @default(autoincrement())
  account_id  Int
  goal_name   String   @db.VarChar(255)
  jlpt_level  String   @db.VarChar(10)
  start_date  DateTime @db.Date
  end_date    DateTime @db.Date
  total_words Int      @default(0)
  daily_words Int      @default(0)
  status      String   @default("active") @db.VarChar(50)
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @updatedAt

  account accounts @relation(fields: [account_id], references: [account_id])
}